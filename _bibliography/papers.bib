@inproceedings{yang2026lucid,
  abbr        = {SIGGRAPH},
  title       = {{LUCID}: Learning Unified Control for Image Deflaring and Exposure Mastery in Nighttime Photography},
  author      = {Yang, Tingyu},
  booktitle   = {ACM SIGGRAPH 2026 Conference Papers},
  year        = {2026},
  website     = {https://xiaoyunyuan.net/index.html?project=lucid},
  selected    = {true},
  abstract    = {We present LUCID, a unified controllable image restoration framework for nighttime photography that jointly handles lens flare removal and exposure adjustment. By combining flare decoupling with Diffusion CFG control, LUCID achieves continuous brightness adjustment through mixed training and supports text-guided light source preservation, enabling multi-mode training and multi-effect inference within a single model. The framework also leverages multi-exposure scene reconstruction for high-quality nighttime HDR synthesis, achieving state-of-the-art IQA metrics on large-scale real-world nighttime datasets.},
}

@inproceedings{yang2026sodiff,
  abbr        = {AAAI},
  title       = {{SODiff}: Semantic-Oriented Diffusion Model for {JPEG} Compression Artifacts Removal},
  author      = {Yang*, Tingyu and others},
  booktitle   = {Proceedings of the AAAI Conference on Artificial Intelligence},
  year        = {2026},
  arxiv       = {2508.07346},
  selected    = {true},
  abstract    = {We propose SODiff, an image restoration method for JPEG compression artifact removal that aligns image features with semantic guidance to better exploit pretrained generative priors. By bridging compressed image features with semantic information, SODiff improves texture reconstruction naturalness and overall perceptual quality under high compression ratios.},
}

@inproceedings{yang2025haodiff,
  abbr        = {NeurIPS},
  title       = {{HAODiff}: Human-Aware One-Step Diffusion via Dual-Prompt Guidance},
  author      = {Yang*, Tingyu and others},
  booktitle   = {Advances in Neural Information Processing Systems},
  year        = {2025},
  arxiv       = {2505.19742},
  website     = {https://gobunu.github.io/HAODiff/},
  selected    = {true},
  abstract    = {HAODiff addresses image restoration for human subjects under complex degradation conditions. By integrating human-aware priors with conditional guidance mechanisms, it enhances the recovery of motion-blurred body regions, maintaining perceptual quality and structural fidelity in challenging real-world degradation scenarios.},
}
